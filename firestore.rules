rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /coaches/{coachId} {
      allow read, write: if request.auth != null && request.auth.uid == coachId;
    }
    match /clients/{clientId} {
      allow read: if request.auth != null && (request.auth.uid == clientId || exists(/databases/$(database)/documents/coaches/$(request.auth.uid)));
      allow write: if request.auth != null && exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }
    match /plans/{planId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }
    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /compendio/{docId} {
      allow read, write: if request.auth != null;
    }
    match /logs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }
    match /fichas_onboarding/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
